# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# package-lock.json is intentionally not committed:
# it gets regenerated cross-platform (Windows dev vs Linux Cloudflare CI)
# which causes npm ci to fail with missing platform-specific optional deps.
# Without a lock file, Cloudflare Pages falls back to `npm install`.
package-lock.json

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# convex
.convex/

# seed corpus (local only — drop files here for scripts/ingest.ts)
/seed/

# cloudflare / opennext
.open-next/
.wrangler/
